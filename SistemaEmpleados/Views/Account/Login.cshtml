@model SistemaEmpleados.Models.ViewModels.LoginViewModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="login-container">
    <div class="login-card animate__animated animate__fadeInUp">

        <!-- Logo -->
        <div class="login-header">
            <h1 class="login-title">Portal RRHH</h1>
            <p class="login-subtitle">Sistema Integral de Control de Empleados</p>
        </div>

        <!-- Errores -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert-error animate__animated animate__shakeX" id="loginError">
                <i class="fa-solid fa-circle-exclamation me-2"></i>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <span>@error.ErrorMessage</span>
                }
            </div>
        }

        <!-- Formulario -->
        <form asp-controller="Account" asp-action="Login" method="post" id="loginForm">
            <input type="hidden" asp-for="ReturnUrl" />
            @Html.AntiForgeryToken()

            <div class="form-group-login">
                <label class="form-label-login" for="Email">
                    <i class="fa-solid fa-envelope me-1"></i> Correo electrónico
                </label>
                <input asp-for="Email"
                       class="form-input-login @(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "input-error" : "")"
                       placeholder="usuario@empresa.com"
                       autocomplete="email"
                       autofocus />
                <span asp-validation-for="Email" class="field-error-msg"></span>
            </div>

            <div class="form-group-login">
                <label class="form-label-login" for="Password">
                    <i class="fa-solid fa-lock me-1"></i> Contraseña
                </label>
                <div class="password-wrapper">
                    <input asp-for="Password"
                           type="password"
                           class="form-input-login @(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "input-error" : "")"
                           placeholder="••••••••"
                           autocomplete="current-password"
                           id="passwordField" />
                    <button type="button" class="password-toggle" onclick="togglePassword()">
                        <i class="fa-solid fa-eye" id="eyeIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="field-error-msg"></span>
            </div>

            <div class="form-check-login">
                <input asp-for="RememberMe" type="checkbox" class="check-custom" id="rememberMe" />
                <label for="rememberMe">Recordar mi sesión (8 horas)</label>
            </div>

            <button type="submit" class="btn-login" id="btnLogin">
                <span id="btnText"><i class="fa-solid fa-right-to-bracket me-2"></i>Ingresar al sistema</span>
                <span id="btnLoader" style="display:none">
                    <span class="spinner-border spinner-border-sm me-2"></span> Verificando...
                </span>
            </button>
        </form>

        <div class="login-footer">
            <p>© @DateTime.Now.Year  Sistema de RRHH </p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword() {
            const field = document.getElementById('passwordField');
            const icon = document.getElementById('eyeIcon');
            if (field.type === 'password') {
                field.type = 'text';
                icon.className = 'fa-solid fa-eye-slash';
            } else {
                field.type = 'password';
                icon.className = 'fa-solid fa-eye';
            }
        }

        document.getElementById('loginForm').addEventListener('submit', function () {
            document.getElementById('btnText').style.display = 'none';
            document.getElementById('btnLoader').style.display = 'inline';
            document.getElementById('btnLogin').disabled = true;
        });
    </script>
}