@model SistemaEmpleados.Models.ViewModels.DocumentoViewModel

@{
    var esEdicion = Model.Id > 0;
    var titulo = esEdicion ? "Editar Documento" : "Nuevo Documento";
}

<div class="modal-header modal-header-documentos">
    <div class="modal-header-inner">
        <div class="modal-header-icon">
            <i class="fa-solid fa-@(esEdicion ? "pen-to-square" : "file-circle-plus")"></i>
        </div>
        <div>
            <h5 class="modal-title">@titulo</h5>
            <small class="text-white-50">@DateTime.Now.ToString("dd/MM/yyyy")</small>
        </div>
    </div>
    <button type="button" class="btn-close btn-close-white"
            onclick="Documentos.cerrarModal()" aria-label="Cerrar"></button>
</div>

<form id="formDocumento" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" name="Id" value="@Model?.Id" />
    <input type="hidden" name="NombreArchivo" id="hiddenNombreArchivo" value="@Model.NombreArchivo" />
    <input type="hidden" name="ContentType" id="hiddenContentType" value="@Model.ContentType" />
    <input type="hidden" name="TamanioBytes" id="hiddenTamanioBytes" value="@Model.TamanioBytes" />

    <div class="modal-body p-0">
        <ul class="nav nav-tabs form-tabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" data-bs-toggle="tab"
                        data-bs-target="#tabDocumento" type="button"
                        role="tab" aria-controls="tabDocumento" aria-selected="true">
                    <i class="fa-solid fa-file me-1"></i>Datos del Documento
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="tabArchivoBtn" data-bs-toggle="tab"
                        data-bs-target="#tabArchivo" type="button"
                        role="tab" aria-controls="tabArchivo" aria-selected="false">
                    <i class="fa-solid fa-paperclip me-1"></i>Archivo
                </button>
            </li>
        </ul>

        <div class="tab-content form-tab-content">

            <div class="tab-pane fade show active" id="tabDocumento" role="tabpanel">
                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="form-label required-field" for="Titulo">Titulo</label>
                        <input type="text" name="Titulo" id="Titulo"
                               class="form-control"
                               value="@Model.Titulo"
                               placeholder="Contrato de trabajo"
                               maxlength="150"
                               required />
                        <div class="invalid-feedback"></div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="selectDepartamento">Departamento</label>
                        <select name="DepartamentoId" id="selectDepartamento" class="form-select">
                            <option value="">— Todos —</option>
                            @if (ViewBag.Departamentos != null)
                            {
                                foreach (var d in ViewBag.Departamentos)
                                {
                                    <option value="@d.Id">@d.Nombre</option>
                                }
                            }
                        </select>
                        <input type="hidden" id="currentDepartamentoId" value="@Model.DepartamentoId" />
                    </div>
                    
                    <div class="col-md-6">
                        <label class="form-label required-field" for="selectEmpleado">Empleado</label>
                        <select name="EmpleadoId" id="selectEmpleado"
                                class="form-select" required>
                            <option value="">— Seleccionar —</option>
                            @if (ViewBag.Empleados != null)
                            {
                                foreach (var e in ViewBag.Empleados)
                                {
                                    <option value="@e.Id">@e.nombre</option>
                                }
                            }
                        </select>
                        <input type="hidden" id="currentEmpleadoId" value="@Model.EmpleadoId" />
                        <div class="invalid-feedback"></div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label required-field" for="Tipo">Tipo de documento</label>
                        <select name="Tipo" id="Tipo" class="form-select" required
                                onchange="Documentos.actualizarNotaLegal()">
                            @foreach (var t in Enum.GetValues<SistemaEmpleados.Models.Entities.TipoDocumento>())
                            {
                                <option value="@((int)t)">@t</option>
                            }
                        </select>
                        <input type="hidden" id="currentTipo" value="@((int)Model.Tipo)" />
                        <div class="invalid-feedback"></div>
                    </div>

                    <div class="col-md-6" id="divModalidad" style="display:none">
                        <label class="form-label" for="Modalidad">Modalidad del contrato</label>
                        <select name="Modalidad" id="Modalidad" class="form-select">
                            <option value="">— Seleccionar —</option>
                            @foreach (var m in Enum.GetValues<SistemaEmpleados.Models.Entities.ModalidadContrato>())
                            {
                                <option value="@((int)m)">@m</option>
                            }
                        </select>
                        <input type="hidden" id="currentModalidad" value="@((int?)Model.Modalidad)" />
                    </div>

                    <div class="col-12" id="notaLegalContainer">
                        <div class="legal-note-box">
                            <i class="fa-solid fa-info-circle me-2"></i>
                            <span id="notaLegalTexto">Seleccione un tipo de documento para ver la normativa aplicable.</span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="Estado">Estado</label>
                        <select name="Estado" id="Estado" class="form-select">
                            @foreach (var e in Enum.GetValues<SistemaEmpleados.Models.Entities.EstadoDocumento>())
                            {
                                <option value="@((int)e)">@e</option>
                            }
                        </select>
                        <input type="hidden" id="currentEstado" value="@((int)Model.Estado)" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="FechaExpiracion">Fecha de expiracion</label>
                        <input type="date" name="FechaExpiracion" id="FechaExpiracion"
                               class="form-control"
                               value="@Model.FechaExpiracion?.ToString("yyyy-MM-dd")" />
                        <input type="hidden" id="currentFechaExp" value="@Model.FechaExpiracion?.ToString("yyyy-MM-dd")" />
                        <small class="text-muted">Dejar vacio si no expira</small>
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="Descripcion">Descripcion</label>
                        <textarea name="Descripcion" id="Descripcion"
                                  class="form-control" rows="2"
                                  maxlength="500"
                                  placeholder="Descripcion adicional...">@Model.Descripcion</textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="Observaciones">Observaciones</label>
                        <textarea name="Observaciones" id="Observaciones"
                                  class="form-control" rows="2"
                                  maxlength="500"
                                  placeholder="Notas adicionales...">@Model.Observaciones</textarea>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="tabArchivo" role="tabpanel" style="min-height:300px">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Subir archivo (PDF, JPG, PNG)</label>
                        <div id="dropZone" style="border:2px dashed #ccc;border-radius:8px;padding:40px;text-align:center;cursor:pointer" onclick="document.getElementById('fileInput').click()">
                            <i class="fa-solid fa-cloud-arrow-up fa-2x" style="font-size:24px;color:#999"></i>
                            <p style="margin:10px 0 5px">Arrastra archivos aqui o haz clic</p>
                            <small style="color:#999">PDF, JPG, PNG (max. 10MB)</small>
                            <input type="file" name="Archivo" id="fileInput" accept=".pdf,.jpg,.jpeg,.png" hidden />
                        </div>
                        
                        <div id="previewArchivo" class="mt-3" style="display:none">
                            <div class="card">
                                <div class="card-body">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div class="d-flex align-items-center">
                                            <i class="fa-solid fa-file-pdf fa-2x me-3 text-danger" id="previewIcono"></i>
                                            <div>
                                                <strong id="previewNombre">documento.pdf</strong>
                                                <div class="text-muted small" id="previewTamano">125 KB</div>
                                            </div>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="Documentos.quitarArchivo()">
                                            <i class="fa-solid fa-times me-1"></i>Quitar
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div id="progressUpload" class="mt-3" style="display:none">
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%"></div>
                            </div>
                            <small class="text-muted mt-1 d-block">Subiendo... <span id="progressPercent">0%</span></small>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="text-center text-muted my-2">— o —</div>
                        <label class="form-label" for="UrlArchivo">URL externa (Drive/OneDrive/GDrive)</label>
                        <input type="url" name="UrlArchivo" id="UrlArchivo"
                               class="form-control"
                               value="@Model.UrlArchivo"
                               placeholder="https://drive.google.com/..." />
                        <small class="text-muted">Alternativa: pega la URL del archivo en la nube</small>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="NumeroFolio">Numero de folio / Referencia</label>
                        <input type="text" name="NumeroFolio" id="NumeroFolio"
                               class="form-control"
                               value="@Model.NumeroFolio"
                               placeholder="FOL-2024-0001"
                               maxlength="50" />
                        <small class="text-muted">Opcional: numero de control interno</small>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary"
                onclick="Documentos.cerrarModal()">
            <i class="fa-solid fa-arrow-left me-2"></i>Cancelar
        </button>
        <button type="submit" class="btn btn-documentos" id="btnGuardarDocumento">
            <i class="fa-solid fa-check me-2"></i>Guardar
        </button>
    </div>
</form>

<script>
    window.notasLegales = {
        'Contrato': 'Segun el Codigo de Trabajo de Guatemala (Decreto 76-76), el contrato de trabajo debe constar por escrito.',
        'Rol': 'El rol de pagos es un documento obligatorio que debe entregarse mensualmente.',
        'Certificado': 'El certificado de salud es requerido por el Ministerio de Trabajo.',
        'Constancia': 'La constancia debe contener datos generales del trabajador.',
        'Credencial': 'Documento interno de identificacion.',
        'Antecedentes': 'Los antecedentes tienen vigencia de 90 dias.',
        'Otro': 'Documento generico.'
    };
</script>