<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SICE - @ViewData["Title"]</title>

    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <link href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/topbar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    @await RenderSectionAsync("HeadStyles", required: false)
</head>
<body>

    <nav class="topbar" id="mainTopbar">
        <div class="topbar-brand">
            <div class="topbar-logo">
                <i class="fa-solid fa-users-gear"></i>
            </div>
            <span class="topbar-title">Portal RRHH</span>
        </div>

        <div class="topbar-nav" id="navModulos">
            <a href="/Home/Index" class="nav-module-link">
                <i class="fa-solid fa-house-chimney"></i> Inicio
            </a>
            @if (User.IsInRole("SuperAdmin") || User.IsInRole("RRHH") || User.IsInRole("Gerente"))
            {
                <div class="nav-dropdown">
                    <button class="nav-module-link nav-dropdown-toggle" type="button">
                        <i class="fa-solid fa-id-badge"></i> Personal
                        <i class="fa-solid fa-chevron-down fa-xs ms-1"></i>
                    </button>
                    <div class="nav-dropdown-menu">
                        <a href="/Personal/Index" class="nav-dropdown-item">
                            <i class="fa-solid fa-users me-2"></i>Empleados
                        </a>
                        <a href="/Configuracion/Index" class="nav-dropdown-item">
                            <i class="fa-solid fa-gear me-2"></i>Departamentos
                        </a>
                    </div>
                </div>
                <a href="/Asistencia/Index" class="nav-module-link">
                    <i class="fa-solid fa-clock"></i> Asistencia
                </a>
                <a href="/Nomina/Index" class="nav-module-link">
                    <i class="fa-solid fa-file-invoice-dollar"></i> Nómina
                </a>
                <a href="/Vacaciones/Index" class="nav-module-link">
                    <i class="fa-solid fa-umbrella-beach"></i> Vacaciones
                </a>
                <a href="/Prestaciones/Index" class="nav-module-link">
                    <i class="fa-solid fa-hand-holding-dollar"></i> Prestaciones
                </a>
                <a href="/Reclutamiento/Index" class="nav-module-link">
                    <i class="fa-solid fa-user-plus"></i> Reclutamiento
                </a>
            
                <a href="/Documentos/Index" class="nav-module-link">
                    <i class="fa-solid fa-folder-open"></i> Documentos
                </a>
                <a href="/Reportes/Index" class="nav-module-link">
                    <i class="fa-solid fa-chart-bar"></i> Reportes
                </a>
            }
            @if (User.IsInRole("Empleado"))
            {
                <a href="/Portal/Index" class="nav-module-link">
                    <i class="fa-solid fa-circle-user"></i> Mi Portal
                </a>
            }
        </div>

        <div class="topbar-user dropdown ms-auto">
            <button class="user-trigger" data-bs-toggle="dropdown">
                <div class="user-avatar">
                    @{
                        var initial = (User.Identity?.Name ?? "U")[0].ToString().ToUpper();
                    }
                    @initial
                </div>
                <div class="user-info d-none d-md-block">
                    <span class="user-name">@(User.Identity?.Name?.Split('@')[0])</span>
                    <span class="user-role-badge">@ViewBag.UserRole</span>
                </div>
                <i class="fa-solid fa-chevron-down fa-xs ms-1"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li>
                    <a class="dropdown-item" href="/Account/Profile">
                        <i class="fa-solid fa-user me-2"></i>Mi Perfil
                    </a>
                </li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                    <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="dropdown-item text-danger">
                            <i class="fa-solid fa-right-from-bracket me-2"></i>Cerrar sesión
                        </button>
                    </form>
                </li>
            </ul>
        </div>
    </nav>

    <main id="main-content" class="main-content">
        @RenderBody()
    </main>

    <div class="modal fade" id="modalEmpleado" tabindex="-1">
        <div class="modal-dialog modal-xl mt-4">
            <div class="modal-content">
                <div id="modalEmpleadoBody">
                    <div class="modal-loading">
                        <div class="spinner-border text-primary" style="width:2.5rem;height:2.5rem"></div>
                        <p>Cargando...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <footer class="site-footer">
        © 2026 SICE — Sistema Integrado de Control Empresarial
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/ajax-helpers.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        (function () {
            var path = window.location.pathname.toLowerCase();

            // Marcar link activo en el navbar
            document.querySelectorAll('.nav-module-link, .nav-dropdown-item').forEach(function (link) {
                try {
                    var lp = new URL(link.href).pathname.toLowerCase();
                    if (lp !== '/' && path.startsWith(lp)) {
                        link.classList.add('active');
                        var dropdown = link.closest('.nav-dropdown');
                        if (dropdown) dropdown.classList.add('open');
                    }
                } catch (_) { }
            });

            // Ocultar nav de módulos en Home y en Perfil
            var nav = document.getElementById('navModulos');
            if (nav) {
                var esDashboard = path === '/'
                    || path === '/home/index'
                    || path === '/home'
                    || path === '/account/profile';
                nav.style.display = esDashboard ? 'none' : 'flex';
            }
        })();

        // Limpiar backdrop de modales al cerrar
        document.addEventListener('hidden.bs.modal', function () {
            document.querySelectorAll('.modal-backdrop').forEach(el => el.remove());
            document.body.classList.remove('modal-open');
            document.body.style.removeProperty('padding-right');
            document.body.style.removeProperty('overflow');
        });
    </script>

</body>
</html>
